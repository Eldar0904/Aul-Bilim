rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /site/content {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /media/assets/items/{assetId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /stories/items/{storyId} {
      allow read: if resource.data.published == true || isSignedIn();
      allow write: if isSignedIn();
    }

    match /programs/items/{programId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /enquiries/items/{enquiryId} {
      allow create: if request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.submittedAt is string;
      allow read, update, delete: if isSignedIn();
    }
  }
}
